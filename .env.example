# -----------------------------------------------------------------------------
# Supabase
# Encontre esses valores em: Supabase Dashboard → Project Settings → API
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://<seu-project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<sua-anon-key>

# DEV ONLY — usuário de teste para sign-in silencioso (nunca usar em produção)
NEXT_PUBLIC_DEV_TEST_EMAIL=test@pesca.dev
NEXT_PUBLIC_DEV_TEST_PASSWORD=<senha-do-usuario-de-teste>
